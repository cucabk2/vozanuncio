generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserCredits {
  email     String   @id
  credits   Int      @default(30)
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Anuncio {
  id        String   @id @default(cuid())
  email     String
  produto   String
  script    String
  estilo    String
  createdAt DateTime @default(now())
}
